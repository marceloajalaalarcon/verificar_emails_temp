# Server
PORT=3000

# Authentication (leave empty to disable API key requirement)
API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMTP
SMTP_TIMEOUT_MS=4000

# Cache (in-memory, TTL in ms — default 1 hour)
CACHE_TTL_MS=3600000

# Greylisting
GREYLISTING_RETRY=true
GREYLISTING_DELAY_MS=3000

# WHOIS (disabled by default — slow ~2-3s per lookup)
WHOIS_ENABLED=true

# Bulk Endpoint
BULK_MAX_EMAILS=50

# Temp Mail Scraper (auto-discovery interval, default 1 hour)
SCRAPER_INTERVAL_MS=3600000
